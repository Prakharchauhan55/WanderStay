<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderLust</title>
</head>
<body>
    <h3><p>All listings</p></h3>
    <form action="/listing/new", method="get">
        <button>Create new Listing</button>
    </form>
    <ul>
    <% for(let listings of allListings){ %>
        <li><a href="/listing/<%= listings._id %>"> <%= listings.title %></a></li>
    <% } %>
</ul>
</body>
</html>

