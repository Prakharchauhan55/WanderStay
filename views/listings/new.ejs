<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderLust</title>
</head>
<body>
    <h3>Create new Listing:</h3>
    <form action="/listing" method="post">
        <input type="text" placeholder="enter title" name="listing[title]" id="">
        <br>
        <textarea placeholder="enter description" name="listing[description]" id=""></textarea>
        <br>
        <input type="text" placeholder="enter image url/link" name="listing[image]" id="">
        <br>
        <input type="number" placeholder="enter price" name="listing[price]" id="">
        <br>
        <input type="text" placeholder="enter location" name="listing[location]" id="">
        <br>
        <input type="text" placeholder="enter country" name="listing[country]" id="">
        <br>
        <button>submit</button>
    </form>
    
</body>
</html>