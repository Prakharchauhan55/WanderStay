
<% layout("/layouts/boilerplate") %>

<body>
    <br>
    <div class="row">
        <div class="col-8 offset-2">
            <h3>Create new Listing:</h3>
            <form action="/listing" method="post">
                <div class="mb-3">
                    <label for="title" class="form-lable">Title</label>
                    <input type="text" placeholder="enter title" name="listing[title]"             class="form-control">
                </div>
                
                <div class="mb-3">
                    <label for="discription" class="form-lable">Discription</label>
                    <textarea placeholder="enter description" name="listing[description]" class="form-control"></textarea>
                </div>
                
                <div class="mb-3">
                    <label for="image" class="form-lable">Image</label>
                    <input type="text" placeholder="enter image url/link" name="listing[image]" class="form-control">
                </div>
                
                <div class="mb-3"><label for="price" class="form-lable">Price</label>
                    <input type="number" placeholder="enter price" name="listing[price]" class="form-control">
                </div>
                
                <div class="row">
                    <div class="mb-3 col-md-7">
                        <label for="location" class="form-lable">Location</label>
                        <input type="text" placeholder="enter location" name="listing[location]" class="form-control">
                    </div>
                
                    <div class="mb-3 col-md-5">
                        <label for="country" class="form-lable">Country</label>
                        <input type="text" placeholder="enter country" name="listing[country]" class="form-control">
                    </div>
                </div>
                
                <button class="btn btn-dark add-btn">submit</button>
                <br><br>
            </form>
        </div>
    </div>
    
</body>
